[Unit]
Description=FlowBoard Gunicorn
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/home/ubuntu/flowboard
Environment="PATH=/home/ubuntu/flowboard/venv/bin"
ExecStart=/home/ubuntu/flowboard/venv/bin/gunicorn -c gunicorn.conf.py app:app

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
